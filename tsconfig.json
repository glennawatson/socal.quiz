{
  "compilerOptions": {
    // Environment Settings
    "module": "NodeNext",
    "target": "ESNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",

    // File Layout
    "outDir": "dist",
    "rootDir": ".",
    "sourceRoot": "/",

    // Output
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "removeComments": true,

    // Module Interop
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "skipLibCheck": true,

    // Node.js native type stripping compatibility
    "erasableSyntaxOnly": true,

    // Strict Checks
    "strict": true,
    "allowUnreachableCode": false,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Linter Checks
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    // Deprecated / redundant options removed:
    // - alwaysStrict, noImplicitAny, strictNullChecks: implied by "strict"
    // - esModuleInterop, allowSyntheticDefaultImports: replaced by verbatimModuleSyntax
    // - forceConsistentCasingInFileNames: default true since TS 5.x
    // - baseUrl: not needed without path aliases in src
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts", "tests"]
}
